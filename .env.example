JIRA_PROJECT_KEY=MEET

# Feishu integration optional
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK_URL=

# Email integration optional
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ChromaDB optional
CHROMA_HOST=
CHROMA_PORT=8000
CHROMA_COLLECTION=meetings
CHROMA_PERSIST_DIR=./data/chroma
