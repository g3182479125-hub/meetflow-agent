# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info

# LLM provider
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# Speech-to-text
WHISPER_MODEL_SIZE=large-v2
WHISPER_DEVICE=cpu
WHISPER_LANGUAGE=zh
HF_TOKEN=

# Jira integration optional
JIRA_SERVER=
JIRA_EMAIL=
